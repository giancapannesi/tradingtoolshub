---
interface Props {
  pros: string[];
  cons: string[];
}
const { pros, cons } = Astro.props;
---
<div class="grid md:grid-cols-2 gap-4">
  <div class="bg-positive/5 border border-positive/20 rounded-xl p-5">
    <h3 class="text-positive font-semibold mb-3 flex items-center gap-2">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
      Pros
    </h3>
    <ul class="space-y-2">
      {pros.map(pro => (
        <li class="flex items-start gap-2 text-sm text-text">
          <span class="text-positive mt-0.5 shrink-0">+</span>
          {pro}
        </li>
      ))}
    </ul>
  </div>
  <div class="bg-negative/5 border border-negative/20 rounded-xl p-5">
    <h3 class="text-negative font-semibold mb-3 flex items-center gap-2">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
      Cons
    </h3>
    <ul class="space-y-2">
      {cons.map(con => (
        <li class="flex items-start gap-2 text-sm text-text">
          <span class="text-negative mt-0.5 shrink-0">-</span>
          {con}
        </li>
      ))}
    </ul>
  </div>
</div>
