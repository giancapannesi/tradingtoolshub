  "how_to_get_hired": {
    "title": "How to Get Hired at a Prop Trading Firm",
    "steps": [
      {
        "step": 1,
        "title": "Build Quantitative Skills",
        "description": "Most institutional prop firms require strong math, statistics, or computer science backgrounds. Study probability, stochastic calculus, and programming (Python, C++). Top firms recruit from MIT, CMU, Princeton, and similar programs."
      },
      {
        "step": 2,
        "title": "Practice Trading Games and Puzzles",
        "description": "Firms like Jane Street, Optiver, and SIG use trading simulations, mental math tests, and probability puzzles in interviews. Practice with resources like brainstellar.com and Green Book probability questions."
      },
      {
        "step": 3,
        "title": "Apply to Internships Early",
        "description": "Most top firms recruit interns 6-12 months in advance. Summer internships are the primary pipeline for full-time hires. Apply by September for the following summer."
      },
      {
        "step": 4,
        "title": "Network and Get Referrals",
        "description": "Attend university career fairs, trading competitions, and industry events. LinkedIn connections to current traders can help get your resume noticed."
      },
      {
        "step": 5,
        "title": "Consider Smaller Firms First",
        "description": "If you can't get into Jane Street or Citadel directly, smaller prop firms like Belvedere, Geneva Trading, or Cutler Group have less competitive hiring and can be excellent stepping stones."
      }
    ]
  },
