---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolCard from '../../components/ToolCard.astro';
import RatingStars from '../../components/RatingStars.astro';
import { getListicles, getToolBySlug, getCategories, getComparisons } from '../../utils/data';
import { pickVariant, AFFILIATE_DISCLOSURE_VARIANTS } from '../../utils/variant';
import fs from 'node:fs';
import path from 'node:path';

export function getStaticPaths() {
  const listicles = getListicles();
  return listicles.map(l => ({
    params: { slug: l.slug },
    props: { listicle: l },
  }));
}

const { listicle } = Astro.props;
const bodyDisclosure = pickVariant(listicle.slug + ':bdisc', AFFILIATE_DISCLOSURE_VARIANTS);
const editorialHtmlPath = path.join(process.cwd(), 'src/content/best-html', `${listicle.slug}.html`);
const editorialHtml = fs.existsSync(editorialHtmlPath)
  ? fs.readFileSync(editorialHtmlPath, 'utf-8')
  : '';
const listicleItems = listicle.tools.map(item =>
  typeof item === 'string' ? { slug: item } : item
);
const editorNotes = new Map(listicleItems
  .filter(item => item.editor_note)
  .map(item => [item.slug, item.editor_note])
);
const tools = listicleItems
  .map(item => getToolBySlug(item.slug))
  .filter(Boolean) as any[];
const categories = getCategories();
const category = categories.find(c => c.slug === listicle.category);
const strongestFeatureCounts = tools.map(tool => ({
  slug: tool.slug,
  name: tool.name,
  supportedFeatures: Object.values(tool.features || {}).filter(Boolean).length,
  price: tool.pricing.starting_price === 0 ? 'Free' : `$${tool.pricing.starting_price}/mo`,
  freeTier: tool.pricing.has_free_tier,
  bestFor: tool.best_for?.[0] || 'General traders',
}));

const methodologyPoints = [
  'Workflow fit: whether the tool solves a specific trading job better than generic alternatives.',
  'Pricing clarity: published entry price, free tier or trial access, and whether important capabilities are locked behind higher plans.',
  'Feature depth: automation, analytics, broker/data integrations, risk controls, alerts, and reporting where relevant to the category.',
  'Practical usability: how likely a trader is to keep using the tool after the first week, not just whether the feature list looks impressive.',
  'Risk and trust: company maturity, payout or data reliability where relevant, and any restrictions traders need to know before paying.',
];

const categoryAdvice: Record<string, string[]> = {
  'prop-firms': [
    'Check daily loss, max loss, and trailing drawdown rules before comparing headline account size.',
    'Confirm which platform is actually available for your instrument: futures, forex, CFDs, stocks, or crypto.',
    'Look at payout timing and consistency rules because a cheap challenge can still be a poor fit.',
  ],
  'trading-journals': [
    'Prioritize broker import, screenshot capture, tagging speed, and analytics you will actually review every week.',
    'A journal is only valuable if logging is easy enough to become habit.',
    'AI coaching should explain recurring behavior and risk patterns, not just summarize P&L.',
  ],
  'news-data-feeds': [
    'Separate delayed data, real-time data, and streaming data because those are different products.',
    'Check API limits and historical depth before building a scanner or automated workflow.',
    'For non-developers, a charting or terminal product may be more useful than raw API access.',
  ],
};
const advice = categoryAdvice[listicle.category] || [
  'Start with the workflow you need solved, then compare price and features.',
  'Check which features are included in the entry plan rather than assuming the headline price covers everything.',
  'Use the ranking as a shortlist, then verify the current plan details before paying.',
];

// Cross-comparisons between tools in this list
const allComparisons = getComparisons();
const toolSlugs = new Set(listicleItems.map(item => item.slug));
const intraComparisons = allComparisons
  .filter(c => toolSlugs.has(c.tool_a) && toolSlugs.has(c.tool_b))
  .slice(0, 6);

// Data-driven meta description for better CTR
const topTools = tools.slice(0, 3);
const toolNames = topTools.map(t => t.name).join(', ');
const remainingToolCount = tools.length - topTools.length;
const toolSummary = remainingToolCount > 0
  ? `${toolNames}, and ${remainingToolCount} more`
  : toolNames;
const topRated = tools[0];
const cheapest = tools.reduce((min, t) => (t.pricing.starting_price ?? Infinity) < (min.pricing.starting_price ?? Infinity) ? t : min, tools[0]);
const cheapestLabel = cheapest.pricing.starting_price === 0 ? 'Free' : `from $${cheapest.pricing.starting_price}/mo`;
const metaDescription = listicle.meta_description || `${listicle.title}: ${toolSummary} ranked by features, pricing, and suitability. #1 pick: ${topRated.name} (${topRated.rating.toFixed(1)}★). Cheapest: ${cheapest.name} (${cheapestLabel}). Updated for 2026.`;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": listicle.title,
    "description": listicle.description,
    "numberOfItems": tools.length,
    "itemListElement": tools.map((t, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": t.name,
      "url": `https://tradingtoolshub.com/review/${t.slug}/`
    }))
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://tradingtoolshub.com/" },
      { "@type": "ListItem", "position": 2, "name": "Best Tools", "item": "https://tradingtoolshub.com/best/" },
      { "@type": "ListItem", "position": 3, "name": listicle.title }
    ]
  }
];
---
<BaseLayout
  title={listicle.title}
  description={metaDescription}
  jsonLd={jsonLd}
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 text-sm text-muted mb-8">
      <a href="/" class="hover:text-text transition-colors">Home</a>
      <span>/</span>
      {category && (
        <>
          <a href={`/categories/${category.slug}/`} class="hover:text-text transition-colors">{category.name}</a>
          <span>/</span>
        </>
      )}
      <span class="text-text">Best of</span>
    </nav>

    <h1 class="text-3xl md:text-4xl font-bold text-text mb-4">{listicle.title}</h1>
    <p class="text-lg text-muted mb-8">{listicle.description}</p>

    {editorialHtml && (
      <article class="article-content mb-10 best-editorial-html" set:html={editorialHtml} />
    )}

    {(listicle.slug.includes('prop-firm') || listicle.slug === 'no-challenge-prop-firms') && (
      <section class="grid sm:grid-cols-2 gap-4 mb-10">
        <a href="/best/prop-firm-deals/" class="bg-card border border-border rounded-xl p-5 hover:border-primary/60 transition-colors">
          <span class="text-xs font-semibold uppercase tracking-wide text-primary">Updated deals</span>
          <h2 class="text-lg font-bold text-text mt-2">Compare current prop-firm offers</h2>
          <p class="text-sm text-muted mt-1">See price per account, billing terms and verification status.</p>
        </a>
        <a href="/guides/prop-firm-drawdown-activation-consistency/" class="bg-card border border-border rounded-xl p-5 hover:border-primary/60 transition-colors">
          <span class="text-xs font-semibold uppercase tracking-wide text-primary">Before you buy</span>
          <h2 class="text-lg font-bold text-text mt-2">Compare drawdown and payout rules</h2>
          <p class="text-sm text-muted mt-1">Understand EOD trailing, intraday trailing, activation fees and consistency.</p>
        </a>
      </section>
    )}

    <!-- Ranking Methodology -->
    <section class="bg-card border border-border rounded-2xl p-6 mb-10">
      <h2 class="text-2xl font-bold text-text mb-3">How We Ranked These Tools</h2>
      <p class="text-sm text-muted leading-relaxed mb-4">
        This ranking is built around real trader workflow fit, not just the highest advertised rating or biggest feature list. We compare the tools against the job a trader is actually trying to do, then weigh pricing, ease of use, feature depth, and practical restrictions.
      </p>
      <div class="grid lg:grid-cols-2 gap-6">
        <div>
          <h3 class="text-sm font-semibold text-text mb-2">Scoring Criteria</h3>
          <ul class="space-y-2">
            {methodologyPoints.map(point => (
              <li class="flex items-start gap-2 text-sm text-muted">
                <span class="text-primary mt-0.5 shrink-0">&#8226;</span> {point}
              </li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="text-sm font-semibold text-text mb-2">What To Check Before Choosing</h3>
          <ul class="space-y-2">
            {advice.map(point => (
              <li class="flex items-start gap-2 text-sm text-muted">
                <span class="text-featured mt-0.5 shrink-0">&#8226;</span> {point}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    {listicle.official_sources?.length > 0 && (
      <section class="bg-card border border-border rounded-2xl p-6 mb-10">
        <h2 class="text-xl font-bold text-text mb-2">Official Program Sources</h2>
        <p class="text-sm text-muted mb-4">
          Program structures and restrictions change. We checked these first-party sources{listicle.last_updated ? ` for the ${listicle.last_updated} update` : ''}; verify the exact account rules before paying.
        </p>
        <ul class="grid sm:grid-cols-2 gap-2">
          {listicle.official_sources.map(source => (
            <li>
              <a href={source.url} target="_blank" rel="noopener" class="text-sm text-primary hover:text-primary-hover transition-colors">
                {source.title} &rarr;
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- Quick Summary Table -->
    <div class="bg-card border border-border rounded-2xl overflow-hidden mb-10">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-border">
              <th class="text-left p-4 text-muted font-medium">#</th>
              <th class="text-left p-4 text-muted font-medium">Tool</th>
              <th class="text-left p-4 text-muted font-medium">Rating</th>
              <th class="text-left p-4 text-muted font-medium">Price</th>
              <th class="text-left p-4 text-muted font-medium">Best For</th>
              <th class="text-right p-4 text-muted font-medium"></th>
            </tr>
          </thead>
          <tbody>
            {tools.map((tool, i) => (
              <tr class={`border-b border-border/50 ${i === 0 ? 'bg-featured/5' : ''}`}>
                <td class="p-4">
                  <span class={`inline-flex items-center justify-center w-7 h-7 rounded-full text-xs font-bold ${i === 0 ? 'bg-featured text-bg' : 'bg-bg text-muted'}`}>
                    {i + 1}
                  </span>
                </td>
                <td class="p-4">
                  <a href={`/review/${tool.slug}/`} class="font-semibold text-text hover:text-primary transition-colors">
                    {tool.name}
                  </a>
                  {i === 0 && <span class="ml-2 text-xs bg-featured/20 text-featured px-2 py-0.5 rounded-full">Editor's Pick</span>}
                </td>
                <td class="p-4">
                  <RatingStars rating={tool.rating} size="sm" />
                </td>
                <td class="p-4 text-text">
                  {tool.pricing.starting_price === 0 ? 'Free' : `$${tool.pricing.starting_price}/mo`}
                </td>
                <td class="p-4 text-muted text-xs">{tool.best_for[0]}</td>
                <td class="p-4 text-right">
                  <a href={`/review/${tool.slug}/`} class="text-primary hover:text-primary-hover text-sm transition-colors">
                    Review &rarr;
                  </a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Decision Snapshot -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-text mb-4">Decision Snapshot</h2>
      <div class="bg-card border border-border rounded-2xl overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-border">
                <th class="text-left p-4 text-muted font-medium">Tool</th>
                <th class="text-left p-4 text-muted font-medium">Entry Price</th>
                <th class="text-left p-4 text-muted font-medium">Free Tier</th>
                <th class="text-left p-4 text-muted font-medium">Feature Breadth</th>
                <th class="text-left p-4 text-muted font-medium">Best Fit</th>
              </tr>
            </thead>
            <tbody>
              {strongestFeatureCounts.map(item => (
                <tr class="border-b border-border/50">
                  <td class="p-4">
                    <a href={`/review/${item.slug}/`} class="font-semibold text-text hover:text-primary transition-colors">{item.name}</a>
                  </td>
                  <td class="p-4 text-text">{item.price}</td>
                  <td class="p-4">
                    <span class={item.freeTier ? 'text-positive' : 'text-muted'}>{item.freeTier ? 'Yes' : 'No'}</span>
                  </td>
                  <td class="p-4 text-muted">{item.supportedFeatures} tracked features</td>
                  <td class="p-4 text-muted">{item.bestFor}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Detailed Cards -->
    {tools.map((tool, i) => (
      <section class="mb-8" id={tool.slug}>
        <div class="bg-card border border-border rounded-xl p-6">
          <div class="flex items-start justify-between mb-4">
            <div>
              <div class="flex items-center gap-3 mb-2">
                <span class={`inline-flex items-center justify-center w-8 h-8 rounded-full text-sm font-bold ${i === 0 ? 'bg-featured text-bg' : 'bg-bg text-muted'}`}>
                  {i + 1}
                </span>
                <h2 class="text-xl font-bold text-text">{tool.name}</h2>
                {i === 0 && <span class="text-xs bg-featured/20 text-featured px-2 py-0.5 rounded-full">Top Pick</span>}
              </div>
              <RatingStars rating={tool.rating} />
            </div>
            <div class="text-right">
              <div class="text-lg font-bold text-text">
                {tool.pricing.starting_price === 0 ? 'Free' : `$${tool.pricing.starting_price}/mo`}
              </div>
              {tool.pricing.has_free_tier && tool.pricing.starting_price > 0 && (
                <span class="text-xs text-positive">Free tier available</span>
              )}
            </div>
          </div>

          <p class="text-muted mb-4">{tool.description_short}</p>
          {editorNotes.has(tool.slug) && (
            <p class="text-sm text-text bg-bg border border-border rounded-lg p-3 mb-4">
              <strong>Editorial note:</strong> {editorNotes.get(tool.slug)}
            </p>
          )}

          <div class="grid md:grid-cols-2 gap-4 mb-4">
            <div>
              <h3 class="text-sm font-semibold text-positive mb-2">Pros</h3>
              <ul class="space-y-1">
                {tool.pros.slice(0, 3).map(p => (
                  <li class="flex items-start gap-2 text-sm text-muted">
                    <span class="text-positive mt-0.5 shrink-0">&#10003;</span> {p}
                  </li>
                ))}
              </ul>
            </div>
            <div>
              <h3 class="text-sm font-semibold text-negative mb-2">Cons</h3>
              <ul class="space-y-1">
                {tool.cons.slice(0, 3).map(c => (
                  <li class="flex items-start gap-2 text-sm text-muted">
                    <span class="text-negative mt-0.5 shrink-0">&#10007;</span> {c}
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <div class="flex flex-wrap gap-3 pt-4 border-t border-border">
            <a href={`/review/${tool.slug}/`} class="inline-flex items-center px-4 py-2 text-sm text-primary hover:text-primary-hover transition-colors">
              Full Review &rarr;
            </a>
            {tool.affiliate_url ? (
              <a href={tool.affiliate_url} target="_blank" rel="nofollow sponsored" class="inline-flex items-center px-5 py-2 bg-primary hover:bg-primary-hover text-white text-sm font-semibold rounded-lg transition-colors">
                Visit {tool.name} &rarr;
              </a>
            ) : (
              <a href={tool.website_url} target="_blank" rel="noopener" class="inline-flex items-center px-5 py-2 bg-primary hover:bg-primary-hover text-white text-sm font-semibold rounded-lg transition-colors">
                Visit {tool.name} &rarr;
              </a>
            )}
          </div>
        </div>
      </section>
    ))}

    <!-- Head-to-Head Comparisons -->
    {intraComparisons.length > 0 && (
      <section class="mb-10">
        <h2 class="text-2xl font-bold text-text mb-4">Head-to-Head Comparisons</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
          {intraComparisons.map(c => {
            const tA = getToolBySlug(c.tool_a);
            const tB = getToolBySlug(c.tool_b);
            return tA && tB && (
              <a href={`/compare/${c.slug}/`} class="flex items-center gap-3 p-4 bg-card border border-border rounded-xl hover:border-primary/50 transition-colors">
                <span class="text-text font-medium text-sm">{tA.name} vs {tB.name}</span>
                <span class="ml-auto text-primary text-sm">&rarr;</span>
              </a>
            );
          })}
        </div>
      </section>
    )}

    <!-- Explore Alternatives -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-text mb-4">Explore Alternatives</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {tools.slice(0, 6).map(tool => (
          <a href={`/alternatives/${tool.slug}/`} class="flex items-center gap-3 p-4 bg-card border border-border rounded-xl hover:border-primary/50 transition-colors">
            <span class="text-text font-medium text-sm">{tool.name} Alternatives</span>
            <span class="ml-auto text-primary text-sm">&rarr;</span>
          </a>
        ))}
      </div>
    </section>

    <!-- Disclosure -->
    <div class="bg-card/50 border border-border rounded-xl p-4 text-xs text-muted">
      {bodyDisclosure}
    </div>
  </div>
</BaseLayout>
