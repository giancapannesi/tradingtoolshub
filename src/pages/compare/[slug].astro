---
import BaseLayout from '../../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';
import ComparisonTable from '../../components/ComparisonTable.astro';
import ProsCons from '../../components/ProsCons.astro';
import RatingStars from '../../components/RatingStars.astro';
import { getComparisons, getToolBySlug, getListicles, getBlogPosts } from '../../utils/data';
import { injectLinks } from '../../utils/inline-linker';
import { repairInternalLinks } from '../../utils/internal-links';
import {
  pickVariant,
  COMPARE_EDITORIAL_HEADINGS,
  QUICK_VERDICT_HEADINGS,
  EXPLORE_MORE_HEADINGS,
  ALSO_COMPARE_HEADINGS,
  AFFILIATE_DISCLOSURE_VARIANTS,
  COMPARE_METHOD_NOTES,
  COMPARE_ARTICLE_TYPES,
  buildCompareMeta,
  buildCompareFaq,
} from '../../utils/variant';

export function getStaticPaths() {
  const comparisons = getComparisons();
  return comparisons.map(c => ({
    params: { slug: c.slug },
    props: { comparison: c },
  }));
}

const { comparison } = Astro.props;
const comparisonHtmlPath = path.join(process.cwd(), 'src/content/compare-html', `${comparison.slug}.html`);
const comparisonHtml = fs.existsSync(comparisonHtmlPath)
  ? fs.readFileSync(comparisonHtmlPath, 'utf8')
  : '';
const toolA = getToolBySlug(comparison.tool_a);
const toolB = getToolBySlug(comparison.tool_b);

if (!toolA || !toolB) {
  return Astro.redirect('/');
}

const winner = toolA.rating >= toolB.rating ? toolA : toolB;
const loser = winner === toolA ? toolB : toolA;
const comparablePrice = (tool: any) => tool.pricing.quote_based ? Infinity : (tool.pricing.starting_price ?? Infinity);
const cheaper = comparablePrice(toolA) <= comparablePrice(toolB) ? toolA : toolB;
const comparisonUpdated = [toolA.last_updated, toolB.last_updated].filter(Boolean).sort().at(-1);

// Per-page section headings & disclosure copy. Seeded by slug so each page
// gets deterministic-but-different boilerplate, killing the verbatim-across-
// the-comparison-base fingerprint.
const editorialHeading = toolA.category && toolA.category === toolB.category
  ? (COMPARE_EDITORIAL_HEADINGS[toolA.category] || 'In-Depth Comparison')
  : 'Cross-Category Comparison';
const quickVerdictHeading = pickVariant(comparison.slug + ':qv', QUICK_VERDICT_HEADINGS);
const exploreMoreHeading = pickVariant(comparison.slug + ':em', EXPLORE_MORE_HEADINGS);
const alsoCompareHeading = pickVariant(comparison.slug + ':ac', ALSO_COMPARE_HEADINGS);
const bodyDisclosure = pickVariant(comparison.slug + ':disc', AFFILIATE_DISCLOSURE_VARIANTS);
const methodNote = pickVariant(comparison.slug + ':method', COMPARE_METHOD_NOTES);

// Related guides for either tool
const allBlogs = getBlogPosts();
const relatedGuides = allBlogs.filter(b =>
  b.related_tools?.includes(comparison.tool_a) ||
  b.related_tools?.includes(comparison.tool_b) ||
  b.slug.includes(comparison.tool_a) ||
  b.slug.includes(comparison.tool_b)
).slice(0, 4);

// Also Compare — related comparisons involving either tool
const allComparisons = getComparisons();
const alsoCompare = allComparisons
  .filter(c =>
    c.slug !== comparison.slug &&
    (c.tool_a === comparison.tool_a || c.tool_b === comparison.tool_a ||
     c.tool_a === comparison.tool_b || c.tool_b === comparison.tool_b)
  )
  .slice(0, 6);

// Data-driven meta description for better CTR — rotated across 6 sentence
// shapes so no single template repeats verbatim across the comparison base.
const fmtPrice = (t: any) => t.pricing.quote_based ? 'quote-based' : t.pricing.starting_price === 0 ? 'Free' : `$${t.pricing.starting_price}/mo`;
const winnerEdgePhrase = winner.pros[0] ? winner.pros[0].toLowerCase().replace(/\.$/, '') : '';
const metaDescription = buildCompareMeta(comparison.slug, {
  toolAName: toolA.name,
  toolBName: toolB.name,
  toolARating: toolA.rating,
  toolBRating: toolB.rating,
  toolAPrice: fmtPrice(toolA),
  toolBPrice: fmtPrice(toolB),
  winnerName: winner.name,
  cheaperName: cheaper.name,
  cheaperPrice: cheaper.pricing.starting_price === 0 ? 'free' : `$${cheaper.pricing.starting_price}/mo`,
  winnerEdge: winnerEdgePhrase,
  category: toolA.category || '',
});

// Build FAQ answers dynamically from tool data
const pricingA = toolA.pricing.quote_based ? 'quote-based' : toolA.pricing.starting_price === 0 ? 'free' : `$${toolA.pricing.starting_price}/mo`;
const pricingB = toolB.pricing.quote_based ? 'quote-based' : toolB.pricing.starting_price === 0 ? 'free' : `$${toolB.pricing.starting_price}/mo`;
const cheaperName = cheaper.name;
const cheaperPrice = cheaper.pricing.starting_price === 0 ? 'a free plan' : `plans starting at $${cheaper.pricing.starting_price}/mo`;
const pricingAnswer = toolA.pricing.quote_based || toolB.pricing.quote_based
  ? `${toolA.name} pricing is ${pricingA}, while ${toolB.name} pricing is ${pricingB}. Request an itemized quote before comparing total cost because datasets and exchange entitlements can materially change institutional pricing.`
  : toolA.pricing.starting_price === toolB.pricing.starting_price
  ? `${toolA.name} and ${toolB.name} have similar starting prices at ${pricingA}. Compare their feature sets to determine which offers better value for your trading needs.`
  : `${cheaperName} is the more affordable option with ${cheaperPrice}. ${toolA.name} starts at ${pricingA} while ${toolB.name} starts at ${pricingB}. However, pricing alone shouldn't drive your decision — consider which features matter most for your trading style.`;

const ratingAnswer = toolA.rating === toolB.rating
  ? `Both ${toolA.name} and ${toolB.name} are rated ${toolA.rating.toFixed(1)}/5 on TradingToolsHub. The best choice depends on your specific trading needs and preferred features.`
  : `${winner.name} has a higher rating of ${winner.rating.toFixed(1)}/5 compared to ${(winner === toolA ? toolB : toolA).name}'s ${(winner === toolA ? toolB : toolA).rating.toFixed(1)}/5. Ratings are based on features, ease of use, value for money, platform reliability, and customer support.`;

// FAQ question SETS rotate — kills the "every compare page has these three
// questions in this order" schema fingerprint.
const faqQuestions = buildCompareFaq(comparison.slug, {
  toolAName: toolA.name,
  toolBName: toolB.name,
  toolADescriptionShort: toolA.description_short,
  toolBDescriptionShort: toolB.description_short,
  toolAPricing: pricingA,
  toolBPricing: pricingB,
  cheaperName: cheaper.name,
  cheaperText: cheaperPrice,
  winnerName: winner.name,
  winnerRating: winner.rating,
  loserName: loser.name,
  loserRating: loser.rating,
  ratingsEqual: toolA.rating === toolB.rating,
  pricingAnswer,
});
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqQuestions.map(q => ({
    "@type": "Question",
    "name": q.name,
    "acceptedAnswer": { "@type": "Answer", "text": q.text },
  })),
};

// Rotate the article @type between Article / Review / TechArticle so schema
// doesn't broadcast "1,179 pages, all the same schema type."
const articleType = pickVariant(comparison.slug + ':atype', COMPARE_ARTICLE_TYPES);
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": articleType,
    "headline": comparison.title,
    "description": metaDescription,
    "datePublished": toolA.last_updated,
    "dateModified": comparisonUpdated,
    "author": {
      "@type": "Organization",
      "name": "TradingToolsHub Editorial",
      "url": "https://tradingtoolshub.com/methodology/"
    },
    "publisher": {
      "@type": "Organization",
      "name": "TradingToolsHub",
      "url": "https://tradingtoolshub.com/"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://tradingtoolshub.com/" },
      { "@type": "ListItem", "position": 2, "name": "Compare", "item": "https://tradingtoolshub.com/compare/" },
      { "@type": "ListItem", "position": 3, "name": `${toolA.name} vs ${toolB.name}` }
    ]
  },
  faqSchema
];
---
<BaseLayout
  title={comparison.title}
  description={comparison.meta_description || metaDescription}
  jsonLd={jsonLd}
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 text-sm text-muted mb-8">
      <a href="/" class="hover:text-text transition-colors">Home</a>
      <span>/</span>
      <span class="text-text">{toolA.name} vs {toolB.name}</span>
    </nav>

    <h1 class="text-3xl md:text-4xl font-bold text-text mb-4">{comparison.title}</h1>
    <p class="text-lg text-muted mb-8">{comparison.summary || `A detailed comparison of ${toolA.name} and ${toolB.name} to help you make the right choice.`}</p>

    <div class="bg-card/60 border border-border rounded-xl p-5 mb-8 text-sm text-muted leading-relaxed">
      <p>{methodNote} <a href="/methodology/" class="text-primary hover:underline">Methodology &rarr;</a></p>
      <div class="flex flex-wrap gap-x-4 gap-y-2 mt-3 text-xs">
        <a href={toolA.website_url} target="_blank" rel="nofollow noopener" class="text-primary hover:underline">Official {toolA.name} source &rarr;</a>
        <a href={toolB.website_url} target="_blank" rel="nofollow noopener" class="text-primary hover:underline">Official {toolB.name} source &rarr;</a>
        {comparisonUpdated && <span class="text-muted">Data checked through {comparisonUpdated}.</span>}
      </div>
    </div>

    <!-- Quick Verdict -->
    <div class="bg-card border border-border rounded-2xl p-6 mb-10">
      <h2 class="text-xl font-bold text-text mb-4">{quickVerdictHeading}</h2>
      <div class="grid md:grid-cols-2 gap-4">
        <div class="bg-bg rounded-xl p-4">
          <p class="text-sm text-muted mb-1">Higher Rated</p>
          <p class="font-semibold text-text">{winner.name} <span class="text-featured">({winner.rating.toFixed(1)})</span></p>
        </div>
        <div class="bg-bg rounded-xl p-4">
          <p class="text-sm text-muted mb-1">More Affordable</p>
          <p class="font-semibold text-text">{cheaper.name} <span class="text-positive">({cheaper.pricing.starting_price === 0 ? 'Free' : `$${cheaper.pricing.starting_price}/mo`})</span></p>
        </div>
      </div>
    </div>

    <!-- Head-to-Head Cards -->
    <div class="grid md:grid-cols-2 gap-4 mb-10">
      {[toolA, toolB].map(tool => (
        <div class="bg-card border border-border rounded-xl p-6">
          <h3 class="text-xl font-bold text-text mb-2">{tool.name}</h3>
          <RatingStars rating={tool.rating} />
          <p class="text-sm text-muted mt-3 mb-4">{tool.description_short}</p>
          <div class="text-sm">
            <span class="text-muted">From: </span>
            <span class="text-text font-medium">{tool.pricing.starting_price === 0 ? 'Free' : `$${tool.pricing.starting_price}/mo`}</span>
          </div>
          <a href={`/review/${tool.slug}/`} class="inline-flex items-center mt-4 text-sm text-primary hover:text-primary-hover transition-colors">
            Full review &rarr;
          </a>
        </div>
      ))}
    </div>

    <!-- Editorial Analysis -->
    {(comparisonHtml || comparison.analysis) && (
      <section class="mb-10">
        <h2 class="text-2xl font-bold text-text mb-4">{editorialHeading}</h2>
        <div class="bg-card border border-border rounded-2xl p-6 md:p-8">
          {comparisonHtml ? (
            <article class="prose prose-invert max-w-none text-muted leading-relaxed space-y-4 compare-editorial-html" set:html={comparisonHtml} />
          ) : (
            <div class="text-muted leading-relaxed space-y-4 text-[15px]" set:html={repairInternalLinks(injectLinks(comparison.analysis.split('\n\n').map(p => `<p>${p}</p>`).join(''), comparison.slug, 6))} />
          )}
        </div>
      </section>
    )}

    <!-- Feature Comparison -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-text mb-4">Feature Comparison</h2>
      <div class="bg-card border border-border rounded-xl overflow-hidden">
        <ComparisonTable toolA={toolA} toolB={toolB} />
      </div>
    </section>

    <!-- Pros & Cons Side by Side -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-text mb-4">{toolA.name}: Pros & Cons</h2>
      <ProsCons pros={toolA.pros} cons={toolA.cons} />
    </section>

    <section class="mb-10">
      <h2 class="text-2xl font-bold text-text mb-4">{toolB.name}: Pros & Cons</h2>
      <ProsCons pros={toolB.pros} cons={toolB.cons} />
    </section>

    <!-- Related Guides -->
    {relatedGuides.length > 0 && (
      <section class="mb-10">
        <h2 class="text-2xl font-bold text-text mb-4">Guides & Tutorials</h2>
        <div class="grid sm:grid-cols-2 gap-3">
          {relatedGuides.map(g => (
            <a href={`/blog/${g.slug}/`} class="group flex items-start gap-4 p-4 bg-card border border-border rounded-xl hover:border-primary/50 transition-colors">
              <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center shrink-0 group-hover:bg-primary/20 transition-colors">
                <span class="text-primary text-lg">&#128214;</span>
              </div>
              <div class="flex-1 min-w-0">
                <span class="text-text font-medium text-sm block truncate">{g.title}</span>
                <span class="text-muted text-xs block mt-1">{g.read_time_minutes} min read</span>
              </div>
              <span class="text-primary text-sm shrink-0 mt-1">&rarr;</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Explore More -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-text mb-4">{exploreMoreHeading}</h2>
      <div class="grid sm:grid-cols-2 gap-3">
        <a href={`/review/${toolA.slug}/`} class="flex items-center gap-3 p-4 bg-card border border-border rounded-xl hover:border-primary/50 transition-colors">
          <span class="text-sm text-text font-medium">{toolA.name} Full Review</span>
          <span class="ml-auto text-primary text-sm">&rarr;</span>
        </a>
        <a href={`/review/${toolB.slug}/`} class="flex items-center gap-3 p-4 bg-card border border-border rounded-xl hover:border-primary/50 transition-colors">
          <span class="text-sm text-text font-medium">{toolB.name} Full Review</span>
          <span class="ml-auto text-primary text-sm">&rarr;</span>
        </a>
        <a href={`/alternatives/${toolA.slug}/`} class="flex items-center gap-3 p-4 bg-card border border-border rounded-xl hover:border-primary/50 transition-colors">
          <span class="text-sm text-text font-medium">{toolA.name} Alternatives</span>
          <span class="ml-auto text-primary text-sm">&rarr;</span>
        </a>
        <a href={`/alternatives/${toolB.slug}/`} class="flex items-center gap-3 p-4 bg-card border border-border rounded-xl hover:border-primary/50 transition-colors">
          <span class="text-sm text-text font-medium">{toolB.name} Alternatives</span>
          <span class="ml-auto text-primary text-sm">&rarr;</span>
        </a>
        {(() => {
          const relatedListicles = getListicles().filter(l => l.tools.includes(toolA.slug) || l.tools.includes(toolB.slug)).slice(0, 2);
          return relatedListicles.map(l => (
            <a href={`/best/${l.slug}/`} class="flex items-center gap-3 p-4 bg-card border border-border rounded-xl hover:border-primary/50 transition-colors">
              <span class="text-featured text-lg">&#9733;</span>
              <span class="text-sm text-text font-medium">{l.title}</span>
              <span class="ml-auto text-primary text-sm">&rarr;</span>
            </a>
          ));
        })()}
      </div>
    </section>

    <!-- Bottom CTAs -->
    <div class="grid md:grid-cols-2 gap-4 mb-10">
      {[toolA, toolB].map(tool => (
        <div class="bg-card border border-border rounded-xl p-6 text-center">
          <h3 class="font-semibold text-text mb-2">Try {tool.name}</h3>
          {tool.affiliate_url ? (
            <a href={tool.affiliate_url} target="_blank" rel="nofollow sponsored" class="inline-flex items-center px-6 py-3 bg-primary hover:bg-primary-hover text-white font-semibold rounded-xl transition-colors">
              Visit {tool.name} &rarr;
            </a>
          ) : (
            <a href={tool.website_url} target="_blank" rel="noopener" class="inline-flex items-center px-6 py-3 bg-primary hover:bg-primary-hover text-white font-semibold rounded-xl transition-colors">
              Visit {tool.name} &rarr;
            </a>
          )}
        </div>
      ))}
    </div>

    <!-- Also Compare -->
    {alsoCompare.length > 0 && (
      <section class="mb-10">
        <h2 class="text-2xl font-bold text-text mb-4">{alsoCompareHeading}</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
          {alsoCompare.map(c => {
            const cToolA = getToolBySlug(c.tool_a);
            const cToolB = getToolBySlug(c.tool_b);
            return cToolA && cToolB && (
              <a href={`/compare/${c.slug}/`} class="flex items-center justify-between p-4 bg-card border border-border rounded-xl hover:border-primary/50 transition-colors">
                <div>
                  <span class="text-text font-medium text-sm">{cToolA.name} vs {cToolB.name}</span>
                  <div class="flex items-center gap-2 mt-1 text-xs text-muted">
                    <span>{cToolA.rating.toFixed(1)}★</span>
                    <span>vs</span>
                    <span>{cToolB.rating.toFixed(1)}★</span>
                  </div>
                </div>
                <span class="text-primary text-sm shrink-0 ml-2">&rarr;</span>
              </a>
            );
          })}
        </div>
      </section>
    )}

    <!-- Disclosure -->
    <div class="bg-card/50 border border-border rounded-xl p-4 text-xs text-muted">
      {bodyDisclosure}
    </div>
  </div>
</BaseLayout>
