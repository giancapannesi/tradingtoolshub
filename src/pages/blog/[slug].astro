---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getBlogPosts, getBlogBySlug, getToolBySlug, getComparisons, getBlogByCategory } from '../../utils/data';

export function getStaticPaths() {
  const posts = getBlogPosts();
  return posts.map(p => ({
    params: { slug: p.slug },
    props: { post: p },
  }));
}

const { post } = Astro.props;

// Related tools
const relatedTools = post.related_tools
  .map(slug => getToolBySlug(slug))
  .filter(Boolean) as any[];

// Related comparisons
const allComparisons = getComparisons();
const relatedComps = post.related_comparisons
  .map(slug => allComparisons.find(c => c.slug === slug))
  .filter(Boolean)
  .slice(0, 5);

// More articles in same category
const categoryPosts = getBlogByCategory(post.category)
  .filter(p => p.slug !== post.slug)
  .slice(0, 3);

// Generate TOC from H2 headings in content
const h2Regex = /<h2[^>]*id="([^"]*)"[^>]*>([^<]*)<\/h2>/g;
const toc: { id: string; text: string }[] = [];
let match;
while ((match = h2Regex.exec(post.content)) !== null) {
  toc.push({ id: match[1], text: match[2] });
}

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": post.title,
    "description": post.meta_description,
    "image": post.image ? `https://tradingtoolshub.com${post.image}` : undefined,
    "author": {
      "@type": "Organization",
      "name": post.author,
      "url": "https://tradingtoolshub.com/about/"
    },
    "publisher": {
      "@type": "Organization",
      "name": "TradingToolsHub",
      "url": "https://tradingtoolshub.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://tradingtoolshub.com/og-default.png"
      }
    },
    "datePublished": post.published_date,
    "dateModified": post.last_updated,
    "mainEntityOfPage": `https://tradingtoolshub.com/blog/${post.slug}/`,
    "wordCount": post.content.split(/\s+/).length,
    "keywords": post.tags.join(', ')
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://tradingtoolshub.com/" },
      { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://tradingtoolshub.com/blog/" },
      { "@type": "ListItem", "position": 3, "name": post.title }
    ]
  }
];
---
<BaseLayout
  title={post.meta_title}
  description={post.meta_description}
  ogImage={post.image ? `https://tradingtoolshub.com${post.image}` : undefined}
  jsonLd={jsonLd}
>
  <article class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 text-sm text-muted mb-6">
      <a href="/" class="hover:text-text transition-colors">Home</a>
      <span>/</span>
      <a href="/blog/" class="hover:text-text transition-colors">Blog</a>
      <span>/</span>
      <span class="text-text truncate max-w-xs">{post.title}</span>
    </nav>

    <div class="lg:grid lg:grid-cols-[1fr_300px] lg:gap-10">
      <!-- Main Content -->
      <div>
        <!-- Header -->
        <header class="mb-8">
          <div class="flex items-center gap-3 mb-4">
            <span class="px-3 py-1 bg-primary/10 text-primary text-xs font-medium rounded-full capitalize">{post.category.replace(/-/g, ' ')}</span>
            <span class="text-sm text-muted">{post.read_time_minutes} min read</span>
          </div>
          <h1 class="text-3xl md:text-4xl font-bold text-text leading-tight mb-4">{post.title}</h1>
          <p class="text-lg text-muted mb-4">{post.excerpt}</p>
          <div class="flex items-center gap-4 text-sm text-muted">
            <span>By {post.author}</span>
            <span>Published {new Date(post.published_date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
            {post.last_updated !== post.published_date && (
              <span>Updated {new Date(post.last_updated).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
            )}
          </div>
        </header>

        <!-- Hero Image -->
        {post.image && (
          <div class="mb-8 rounded-xl overflow-hidden border border-border">
            <img src={post.image} alt={post.image_alt} class="w-full h-auto" loading="eager" />
          </div>
        )}

        <!-- Table of Contents -->
        {toc.length > 2 && (
          <nav class="bg-card border border-border rounded-xl p-6 mb-8">
            <h2 class="font-semibold text-text mb-3 text-sm uppercase tracking-wide">Table of Contents</h2>
            <ol class="space-y-2">
              {toc.map((item, i) => (
                <li>
                  <a href={`#${item.id}`} class="text-muted hover:text-primary text-sm transition-colors flex items-center gap-2">
                    <span class="text-primary/50 font-mono text-xs">{(i + 1).toString().padStart(2, '0')}</span>
                    {item.text}
                  </a>
                </li>
              ))}
            </ol>
          </nav>
        )}

        <!-- Article Body -->
        <div class="prose prose-invert prose-lg max-w-none
          prose-headings:text-text prose-headings:font-bold
          prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4 prose-h2:border-b prose-h2:border-border prose-h2:pb-2
          prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
          prose-p:text-muted prose-p:leading-relaxed prose-p:mb-4
          prose-a:text-primary prose-a:no-underline hover:prose-a:underline
          prose-strong:text-text
          prose-li:text-muted
          prose-ul:pl-6 prose-ol:pl-6
          prose-blockquote:border-l-primary prose-blockquote:bg-card prose-blockquote:rounded-r-lg prose-blockquote:py-2 prose-blockquote:px-4
          prose-code:text-primary prose-code:bg-card prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded
          prose-table:border-border
          prose-th:text-text prose-th:bg-card prose-th:px-4 prose-th:py-2
          prose-td:text-muted prose-td:px-4 prose-td:py-2 prose-td:border-border
        " set:html={post.content} />

        <!-- Tags -->
        <div class="mt-10 pt-6 border-t border-border">
          <div class="flex flex-wrap gap-2">
            {post.tags.map(tag => (
              <span class="px-3 py-1 bg-card border border-border rounded-full text-xs text-muted">{tag}</span>
            ))}
          </div>
        </div>

        <!-- Related Tools CTA -->
        {relatedTools.length > 0 && (
          <div class="mt-10 bg-card border border-border rounded-xl p-6">
            <h2 class="text-xl font-bold text-text mb-4">Tools Mentioned in This Article</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {relatedTools.map(tool => (
                <a href={`/review/${tool.slug}/`} class="flex items-center gap-3 p-3 bg-bg rounded-lg border border-border hover:border-primary/50 transition-colors group">
                  <div class="flex-1">
                    <h3 class="font-semibold text-text group-hover:text-primary transition-colors text-sm">{tool.name}</h3>
                    <p class="text-xs text-muted mt-0.5">{tool.rating.toFixed(1)}/5 — {tool.pricing.starting_price === 0 ? 'Free' : `$${tool.pricing.starting_price}/mo`}</p>
                  </div>
                  <span class="text-muted group-hover:text-primary transition-colors text-sm">Review &rarr;</span>
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- Compare CTA -->
        {relatedComps.length > 0 && (
          <div class="mt-6 bg-card border border-border rounded-xl p-6">
            <h2 class="text-lg font-bold text-text mb-3">Compare These Tools</h2>
            <div class="space-y-2">
              {relatedComps.map(comp => (
                <a href={`/compare/${comp.slug}/`} class="flex items-center justify-between p-3 bg-bg rounded-lg border border-border hover:border-primary/50 transition-colors group">
                  <span class="text-sm text-muted group-hover:text-text transition-colors">{comp.title}</span>
                  <span class="text-xs text-primary">Compare &rarr;</span>
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- More Articles -->
        {categoryPosts.length > 0 && (
          <div class="mt-10">
            <h2 class="text-xl font-bold text-text mb-4">More Articles</h2>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
              {categoryPosts.map(p => (
                <a href={`/blog/${p.slug}/`} class="bg-card border border-border rounded-xl p-4 hover:border-primary/50 transition-colors group">
                  {p.image && <img src={p.image} alt={p.image_alt} class="w-full h-32 object-cover rounded-lg mb-3" loading="lazy" />}
                  <h3 class="font-semibold text-text group-hover:text-primary transition-colors text-sm leading-snug">{p.title}</h3>
                  <p class="text-xs text-muted mt-1">{p.read_time_minutes} min read</p>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>

      <!-- Sidebar -->
      <aside class="hidden lg:block space-y-6 mt-8 lg:mt-0">
        <!-- Email Signup -->
        <div class="bg-card border border-border rounded-xl p-5 sticky top-24">
          <h3 class="font-semibold text-text mb-2">Weekly Trading Tools Roundup</h3>
          <p class="text-xs text-muted mb-3">Best deals, new tools, and comparison insights. Every week.</p>
          <form id="blog-subscribe-form" class="space-y-2">
            <input type="email" id="blog-subscribe-email" placeholder="you@email.com" required class="w-full px-3 py-2 bg-bg border border-border rounded-lg text-sm text-text placeholder-muted focus:outline-none focus:border-primary" />
            <button type="submit" id="blog-subscribe-btn" class="w-full px-3 py-2 bg-primary hover:bg-primary-hover text-white rounded-lg text-sm font-medium transition-colors">Subscribe Free</button>
          </form>
          <p id="blog-subscribe-msg" class="text-xs mt-2 hidden"></p>
        </div>

        <!-- Popular Tools -->
        {relatedTools.length > 0 && (
          <div class="bg-card border border-border rounded-xl p-5">
            <h3 class="font-semibold text-text mb-3 text-sm">Related Reviews</h3>
            <div class="space-y-3">
              {relatedTools.slice(0, 4).map(tool => (
                <a href={`/review/${tool.slug}/`} class="flex items-center gap-2 group">
                  <div class="flex-1">
                    <p class="text-sm text-text group-hover:text-primary transition-colors font-medium">{tool.name}</p>
                    <p class="text-xs text-muted">{tool.rating.toFixed(1)}/5</p>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}
      </aside>
    </div>
  </article>

  <script>
    document.getElementById('blog-subscribe-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = (document.getElementById('blog-subscribe-email') as HTMLInputElement)?.value;
      const btn = document.getElementById('blog-subscribe-btn') as HTMLButtonElement;
      const msg = document.getElementById('blog-subscribe-msg') as HTMLElement;
      if (!email) return;
      btn.disabled = true;
      btn.textContent = '...';
      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });
        if (res.ok) {
          msg.textContent = "You're in! Check your inbox.";
          msg.className = 'text-xs mt-2 text-positive';
          (document.getElementById('blog-subscribe-email') as HTMLInputElement).value = '';
        } else {
          msg.textContent = 'Something went wrong. Try again.';
          msg.className = 'text-xs mt-2 text-negative';
        }
      } catch {
        msg.textContent = 'Network error. Try again.';
        msg.className = 'text-xs mt-2 text-negative';
      }
      btn.disabled = false;
      btn.textContent = 'Subscribe Free';
    });
  </script>
</BaseLayout>
