---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getBlogPosts } from '../../utils/data';

const posts = getBlogPosts();
const categories = [...new Set(posts.map(p => p.category))].sort();

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Trading Blog — Guides, Strategies & Tool Reviews",
    "description": "Expert trading guides, platform tutorials, prop firm strategies, and tool comparisons from TradingToolsHub.",
    "url": "https://tradingtoolshub.com/blog/",
    "publisher": {
      "@type": "Organization",
      "name": "TradingToolsHub",
      "url": "https://tradingtoolshub.com"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://tradingtoolshub.com/" },
      { "@type": "ListItem", "position": 2, "name": "Blog" }
    ]
  }
];
---
<BaseLayout
  title="Trading Blog — Guides, Strategies & Tool Reviews"
  description={`${posts.length} expert articles on trading strategies, platform tutorials, prop firm guides, and tool comparisons. Updated weekly by TradingToolsHub.`}
  jsonLd={jsonLd}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 text-sm text-muted mb-6">
      <a href="/" class="hover:text-text transition-colors">Home</a>
      <span>/</span>
      <span class="text-text">Blog</span>
    </nav>

    <!-- Header -->
    <div class="mb-10">
      <h1 class="text-3xl md:text-4xl font-bold text-text mb-3">Trading Blog</h1>
      <p class="text-lg text-muted max-w-2xl">Expert guides, platform tutorials, prop firm strategies, and tool comparisons to help you trade smarter.</p>
    </div>

    <!-- Category Filter -->
    {categories.length > 1 && (
      <div class="flex flex-wrap gap-2 mb-8">
        <button data-filter="all" class="filter-btn px-4 py-1.5 rounded-full text-sm font-medium bg-primary text-white transition-colors">All</button>
        {categories.map(cat => (
          <button data-filter={cat} class="filter-btn px-4 py-1.5 rounded-full text-sm font-medium bg-card text-muted border border-border hover:text-text hover:border-primary/50 transition-colors capitalize">{cat.replace(/-/g, ' ')}</button>
        ))}
      </div>
    )}

    <!-- Posts Grid -->
    {posts.length === 0 ? (
      <div class="text-center py-20">
        <p class="text-muted text-lg">Articles coming soon. Check back shortly.</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="posts-grid">
        {posts.map(post => (
          <a href={`/blog/${post.slug}/`} class="post-card bg-card border border-border rounded-xl overflow-hidden hover:border-primary/50 transition-all duration-200 hover:-translate-y-0.5 group flex flex-col" data-category={post.category}>
            {post.image && (
              <div class="aspect-[16/9] overflow-hidden">
                <img src={post.image} alt={post.image_alt} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
              </div>
            )}
            <div class="p-5 flex flex-col flex-1">
              <div class="flex items-center gap-2 mb-3">
                <span class="px-2.5 py-0.5 bg-primary/10 text-primary text-xs font-medium rounded-full capitalize">{post.category.replace(/-/g, ' ')}</span>
                <span class="text-xs text-muted">{post.read_time_minutes} min</span>
              </div>
              <h2 class="font-bold text-text group-hover:text-primary transition-colors mb-2 leading-snug">{post.title}</h2>
              <p class="text-sm text-muted line-clamp-2 flex-1">{post.excerpt}</p>
              <div class="flex items-center justify-between mt-4 pt-3 border-t border-border">
                <span class="text-xs text-muted">{new Date(post.published_date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                <span class="text-xs text-primary font-medium">Read more &rarr;</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>

  <script>
    document.querySelectorAll('.filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = btn.getAttribute('data-filter');
        document.querySelectorAll('.filter-btn').forEach(b => {
          b.classList.remove('bg-primary', 'text-white');
          b.classList.add('bg-card', 'text-muted');
        });
        btn.classList.remove('bg-card', 'text-muted');
        btn.classList.add('bg-primary', 'text-white');
        document.querySelectorAll('.post-card').forEach(card => {
          const cat = card.getAttribute('data-category');
          if (filter === 'all' || cat === filter) {
            (card as HTMLElement).style.display = '';
          } else {
            (card as HTMLElement).style.display = 'none';
          }
        });
      });
    });
  </script>
</BaseLayout>
