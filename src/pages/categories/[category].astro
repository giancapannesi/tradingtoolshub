---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolCard from '../../components/ToolCard.astro';
import { getCategories, getToolsByCategory, getListicles, getComparisons, getToolBySlug } from '../../utils/data';

export function getStaticPaths() {
  const categories = getCategories();
  return categories.map(cat => ({
    params: { category: cat.slug },
    props: { category: cat },
  }));
}

const { category } = Astro.props;
const tools = getToolsByCategory(category.slug);
const allCategories = getCategories();

// Related category mapping for cross-linking
const relatedMap: Record<string, string[]> = {
  'trading-journals': ['charting-platforms', 'risk-management', 'trading-education'],
  'charting-platforms': ['stock-screeners', 'trading-journals', 'options-platforms'],
  'stock-screeners': ['charting-platforms', 'news-data-feeds', 'brokers-us'],
  'brokers-us': ['brokers-forex', 'options-platforms', 'stock-screeners'],
  'brokers-forex': ['brokers-us', 'prop-firms', 'futures-platforms'],
  'prop-firms': ['brokers-forex', 'futures-platforms', 'trading-education'],
  'trading-education': ['trading-journals', 'risk-management', 'charting-platforms'],
  'options-platforms': ['brokers-us', 'charting-platforms', 'risk-management'],
  'futures-platforms': ['brokers-forex', 'prop-firms', 'charting-platforms'],
  'trading-bots': ['charting-platforms', 'stock-screeners', 'risk-management'],
  'risk-management': ['trading-journals', 'trading-bots', 'trading-education'],
  'news-data-feeds': ['stock-screeners', 'charting-platforms', 'brokers-us'],
};
const relatedCats = (relatedMap[category.slug] || [])
  .map(slug => allCategories.find(c => c.slug === slug))
  .filter(Boolean);

// Listicles for this category
const categoryListicles = getListicles().filter(l => l.category === category.slug);

// Top comparisons within this category
const catToolSlugs = new Set(tools.map(t => t.slug));
const categoryComparisons = getComparisons()
  .filter(c => catToolSlugs.has(c.tool_a) && catToolSlugs.has(c.tool_b))
  .slice(0, 6);

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": category.seo_title,
    "description": category.seo_description,
    "url": `https://tradingtoolshub.com/categories/${category.slug}/`,
    "mainEntity": {
      "@type": "ItemList",
      "numberOfItems": tools.length,
      "itemListElement": tools.map((t, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "name": t.name,
        "url": `https://tradingtoolshub.com/review/${t.slug}/`,
        "item": {
          "@type": "SoftwareApplication",
          "name": t.name,
          "url": `https://tradingtoolshub.com/review/${t.slug}/`,
          "description": t.description_short,
          "applicationCategory": "FinanceApplication",
          "aggregateRating": {
            "@type": "AggregateRating",
            "ratingValue": t.rating.toFixed(1),
            "bestRating": "5",
            "worstRating": "1",
            "ratingCount": Math.max(1, Math.round(t.rating * 20))
          },
          "offers": {
            "@type": "Offer",
            "price": t.pricing.starting_price.toString(),
            "priceCurrency": t.pricing.currency || "USD"
          }
        }
      }))
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://tradingtoolshub.com/" },
      { "@type": "ListItem", "position": 2, "name": category.name }
    ]
  }
];
---
<BaseLayout
  title={category.seo_title}
  description={category.seo_description}
  jsonLd={jsonLd}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 text-sm text-muted mb-8">
      <a href="/" class="hover:text-text transition-colors">Home</a>
      <span>/</span>
      <span class="text-text">{category.name}</span>
    </nav>

    <div class="mb-10">
      <h1 class="text-3xl md:text-4xl font-bold text-text mb-3">{category.name}</h1>
      <p class="text-lg text-muted max-w-2xl">{category.description}</p>
      <p class="text-sm text-muted mt-2">{tools.length} tools compared</p>
    </div>

    {tools.length === 0 ? (
      <div class="bg-card border border-border rounded-xl p-12 text-center">
        <p class="text-muted">No tools listed in this category yet. Check back soon!</p>
      </div>
    ) : (
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
        {tools.map(tool => (
          <ToolCard
            name={tool.name}
            slug={tool.slug}
            category={tool.category}
            description_short={tool.description_short}
            rating={tool.rating}
            pricing={tool.pricing}
            markets={tool.markets}
            best_for={tool.best_for}
          />
        ))}
      </div>
    )}

    <!-- Best Of Lists -->
    {categoryListicles.length > 0 && (
      <section class="mt-12">
        <h2 class="text-2xl font-bold text-text mb-4">Best Of Lists</h2>
        <div class="grid sm:grid-cols-2 gap-3">
          {categoryListicles.map(l => (
            <a href={`/best/${l.slug}/`} class="flex items-center gap-3 p-4 bg-card border border-border rounded-xl hover:border-primary/50 transition-colors">
              <span class="text-featured text-lg">&#9733;</span>
              <span class="text-text font-medium text-sm">{l.title}</span>
              <span class="ml-auto text-primary text-sm">&rarr;</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Popular Comparisons -->
    {categoryComparisons.length > 0 && (
      <section class="mt-10">
        <h2 class="text-2xl font-bold text-text mb-4">Popular Comparisons</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
          {categoryComparisons.map(c => {
            const tA = getToolBySlug(c.tool_a);
            const tB = getToolBySlug(c.tool_b);
            return tA && tB && (
              <a href={`/compare/${c.slug}/`} class="flex items-center gap-3 p-4 bg-card border border-border rounded-xl hover:border-primary/50 transition-colors">
                <span class="text-text font-medium text-sm">{tA.name} vs {tB.name}</span>
                <span class="ml-auto text-primary text-sm">&rarr;</span>
              </a>
            );
          })}
        </div>
      </section>
    )}
    <!-- Related Categories -->
    {relatedCats.length > 0 && (
      <section class="mt-10">
        <h2 class="text-2xl font-bold text-text mb-4">Related Categories</h2>
        <div class="grid sm:grid-cols-3 gap-3">
          {relatedCats.map(rc => {
            const rcTools = getToolsByCategory(rc.slug);
            return (
              <a href={`/categories/${rc.slug}/`} class="p-4 bg-card border border-border rounded-xl hover:border-primary/50 transition-colors">
                <span class="text-text font-medium text-sm block">{rc.name}</span>
                <span class="text-xs text-muted mt-1 block">{rcTools.length} tools compared</span>
              </a>
            );
          })}
        </div>
      </section>
    )}
  </div>
</BaseLayout>
