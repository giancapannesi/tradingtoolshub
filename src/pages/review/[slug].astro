---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RatingStars from '../../components/RatingStars.astro';
import ProsCons from '../../components/ProsCons.astro';
import ToolCard from '../../components/ToolCard.astro';
import { getAllTools, getToolBySlug, getSimilarTools, getFeatureLabel, getCategories, getComparisons, getListicles, getBlogPosts } from '../../utils/data';

export function getStaticPaths() {
  const tools = getAllTools();
  return tools.map(t => ({ params: { slug: t.slug }, props: { tool: t } }));
}

const { tool } = Astro.props;
const similarTools = getSimilarTools(tool, 3);
const categories = getCategories();
const category = categories.find(c => c.slug === tool.category);

// Internal linking data
const allComparisons = getComparisons();
const toolComparisons = allComparisons
  .filter(c => c.tool_a === tool.slug || c.tool_b === tool.slug)
  .slice(0, 6);
const toolListicles = getListicles()
  .filter(l => l.tools.includes(tool.slug));
const featureKeys = Object.keys(tool.features) as (keyof typeof tool.features)[];

// Related guides & blog posts
const allBlogs = getBlogPosts();
const toolGuides = allBlogs.filter(b =>
  b.related_tools?.includes(tool.slug) ||
  b.slug.includes(tool.slug) ||
  b.tags?.some(t => t.toLowerCase() === tool.name.toLowerCase())
);

// Build FAQ schema for review pages
const pricingText = tool.pricing.starting_price === 0
  ? `${tool.name} offers a free plan. ${tool.pricing.tiers.length > 1 ? `Paid plans start at $${tool.pricing.tiers.find(t => t.price_monthly > 0)?.price_monthly || 'N/A'}/month.` : ''}`
  : `${tool.name} starts at $${tool.pricing.starting_price}/month. ${tool.pricing.has_free_tier ? 'A free tier is also available.' : 'There is no free tier.'} ${tool.pricing.tiers.length > 1 ? `Plans range from $${tool.pricing.tiers[0].price_monthly} to $${tool.pricing.tiers[tool.pricing.tiers.length - 1].price_monthly}/month.` : ''}`;

const prosText = tool.pros.slice(0, 3).join(', ');
const consText = tool.cons.slice(0, 3).join(', ');

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `How much does ${tool.name} cost?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": pricingText.trim()
      }
    },
    {
      "@type": "Question",
      "name": `Is ${tool.name} good for trading?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `${tool.name} is rated ${tool.rating.toFixed(1)}/5 on TradingToolsHub. Key strengths: ${prosText}. Potential drawbacks: ${consText}. It's best suited for ${tool.best_for}.`
      }
    },
    {
      "@type": "Question",
      "name": `Does ${tool.name} have a free plan?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": tool.pricing.has_free_tier
          ? `Yes, ${tool.name} offers a free plan. It includes ${tool.pricing.tiers[0]?.features?.slice(0, 2).join(' and ') || 'basic features'}. Upgrade to a paid plan for full access.`
          : `No, ${tool.name} does not currently offer a free plan. The lowest-priced plan starts at $${tool.pricing.starting_price}/month. Some plans may offer a free trial period.`
      }
    }
  ]
};

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": tool.name,
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "Web",
    "url": tool.website_url,
    "offers": {
      "@type": "AggregateOffer",
      "lowPrice": String(tool.pricing.starting_price),
      "highPrice": String(tool.pricing.tiers[tool.pricing.tiers.length - 1]?.price_monthly || tool.pricing.starting_price),
      "priceCurrency": tool.pricing.currency
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": String(tool.rating),
      "bestRating": "5",
      "ratingCount": "1"
    },
    "review": {
      "@type": "Review",
      "author": { "@type": "Organization", "name": "TradingToolsHub" },
      "reviewRating": { "@type": "Rating", "ratingValue": String(tool.rating), "bestRating": "5" },
      "datePublished": tool.last_updated
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://tradingtoolshub.com/" },
      { "@type": "ListItem", "position": 2, "name": category?.name || tool.category, "item": `https://tradingtoolshub.com/categories/${tool.category}/` },
      { "@type": "ListItem", "position": 3, "name": tool.name }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": `${tool.name} Review 2026`,
    "speakable": {
      "@type": "SpeakableSpecification",
      "cssSelector": ["h1", ".prose", "h2"]
    }
  },
  faqSchema
];
---
<BaseLayout
  title={tool.meta_title || `${tool.name} Review 2026 — Pricing, Features, Pros & Cons`}
  description={tool.meta_description || tool.description_short}
  jsonLd={jsonLd}
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 text-sm text-muted mb-8">
      <a href="/" class="hover:text-text transition-colors">Home</a>
      <span>/</span>
      <a href={`/categories/${tool.category}/`} class="hover:text-text transition-colors">{category?.name || tool.category}</a>
      <span>/</span>
      <span class="text-text">{tool.name}</span>
    </nav>

    <!-- Hero -->
    <div class="bg-card border border-border rounded-2xl p-8 mb-8">
      <div class="flex flex-col md:flex-row items-start gap-6">
        <div class="flex-1">
          <h1 class="text-3xl md:text-4xl font-bold text-text mb-3">{tool.name}</h1>
          <p class="text-lg text-muted mb-4">{tool.description_short}</p>
          <div class="flex items-center gap-4 mb-4">
            <RatingStars rating={tool.rating} size="lg" />
          </div>
          <div class="flex flex-wrap gap-2 mb-6">
            {tool.markets.map(m => (
              <span class="inline-flex items-center px-3 py-1 text-sm bg-bg border border-border rounded-lg text-muted">{m}</span>
            ))}
          </div>
          <div class="flex gap-3">
            {tool.affiliate_url ? (
              <a href={tool.affiliate_url} target="_blank" rel="nofollow sponsored" class="inline-flex items-center px-6 py-3 bg-primary hover:bg-primary-hover text-white font-semibold rounded-xl transition-colors">
                Visit {tool.name} &rarr;
              </a>
            ) : (
              <a href={tool.website_url} target="_blank" rel="noopener" class="inline-flex items-center px-6 py-3 bg-primary hover:bg-primary-hover text-white font-semibold rounded-xl transition-colors">
                Visit {tool.name} &rarr;
              </a>
            )}
          </div>
        </div>
        <div class="w-full md:w-64 shrink-0">
          <div class="bg-bg border border-border rounded-xl p-5">
            <h3 class="font-semibold text-text mb-3">Quick Facts</h3>
            <dl class="space-y-2 text-sm">
              <div class="flex justify-between">
                <dt class="text-muted">Starting Price</dt>
                <dd class="text-text font-medium">{tool.pricing.starting_price === 0 ? 'Free' : `$${tool.pricing.starting_price}/mo`}</dd>
              </div>
              <div class="flex justify-between">
                <dt class="text-muted">Free Tier</dt>
                <dd class={tool.pricing.has_free_tier ? 'text-positive font-medium' : 'text-muted'}>{tool.pricing.has_free_tier ? 'Yes' : 'No'}</dd>
              </div>
              <div class="flex justify-between">
                <dt class="text-muted">Founded</dt>
                <dd class="text-text">{tool.founded_year}</dd>
              </div>
              <div class="flex justify-between">
                <dt class="text-muted">Company</dt>
                <dd class="text-text text-right">{tool.company}</dd>
              </div>
            </dl>
            {tool.social_links && Object.keys(tool.social_links).length > 0 && (
              <div class="mt-4 pt-3 border-t border-border">
                <h4 class="text-xs font-semibold text-muted mb-2 uppercase tracking-wider">Official Channels</h4>
                <div class="flex flex-wrap gap-2">
                  {Object.entries(tool.social_links).map(([platform, url]) => (
                    <a href={url} target="_blank" rel="nofollow noopener" class="inline-flex items-center px-2 py-1 text-xs bg-bg border border-border rounded-lg text-muted hover:text-text hover:border-primary/50 transition-colors capitalize">
                      {platform === 'twitter' ? 'X/Twitter' : platform}
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        </div>
      </div>
    </div>

    <!-- Review Header Image -->
    {tool.review_image && (
      <div class="mb-8 rounded-2xl overflow-hidden">
        <img src={tool.review_image} alt={`${tool.name} review`} width="1200" height="630" class="w-full h-auto" loading="eager" />
      </div>
    )}

    <!-- Overview -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-text mb-4">{tool.name} Overview</h2>
      <div class="prose prose-invert max-w-none text-muted leading-relaxed space-y-4" set:html={
        tool.description_long
          .split('\n\n')
          .map(block => {
            const trimmed = block.trim();
            if (trimmed.startsWith('## ')) {
              return `<h3 class="text-xl font-bold text-text mt-8 mb-3">${trimmed.slice(3)}</h3>`;
            }
            // Convert **bold** and *italic*
            let html = trimmed
              .replace(/\*\*(.+?)\*\*/g, '<strong class="text-text">$1</strong>')
              .replace(/\*(.+?)\*/g, '<em>$1</em>')
              .replace(/\n/g, '<br/>');
            return `<p>${html}</p>`;
          })
          .join('')
      } />
    </section>

    <!-- Screenshots Gallery -->
    {tool.screenshots && tool.screenshots.length > 0 && (
      <section class="mb-10">
        <h2 class="text-2xl font-bold text-text mb-4">{tool.name} Screenshots</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {tool.screenshots.map((s: any) => (
            <figure class="bg-card border border-border rounded-xl overflow-hidden group">
              <a href={s.path} target="_blank" class="block">
                <img
                  src={s.path}
                  alt={s.alt}
                  loading="lazy"
                  width="720"
                  height="450"
                  class="w-full h-auto object-cover transition-transform duration-200 group-hover:scale-[1.02]"
                />
              </a>
              <figcaption class="px-4 py-2 text-xs text-muted capitalize">{s.label.replace(/-/g, ' ')}</figcaption>
            </figure>
          ))}
        </div>
      </section>
    )}

    <!-- Pricing -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-text mb-4">{tool.name} Pricing</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {tool.pricing.tiers.map((tier, i) => (
          <div class={`bg-card border rounded-xl p-5 ${i === 1 ? 'border-primary ring-1 ring-primary/20' : 'border-border'}`}>
            {i === 1 && <span class="text-xs font-semibold text-primary mb-2 block">Most Popular</span>}
            <h3 class="font-semibold text-text mb-1">{tier.name}</h3>
            <div class="text-2xl font-bold text-text mb-1">
              {tier.price_monthly === 0 ? 'Free' : `$${tier.price_monthly}`}
              {tier.price_monthly > 0 && <span class="text-sm font-normal text-muted">/mo</span>}
            </div>
            {tier.price_yearly > 0 && (
              <p class="text-xs text-muted mb-3">${(tier.price_yearly / 12).toFixed(2)}/mo billed yearly</p>
            )}
            {tier.features && tier.features.length > 0 && (
              <ul class="space-y-1.5">
                {tier.features.map(f => (
                  <li class="flex items-start gap-2 text-sm text-muted">
                    <span class="text-positive mt-0.5 shrink-0">&#10003;</span> {f}
                  </li>
                ))}
              </ul>
            )}
          </div>
        ))}
      </div>
    </section>

    <!-- Features -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-text mb-4">Features</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
        {featureKeys.map(key => (
          <div class={`flex items-center gap-2 p-3 rounded-lg text-sm ${tool.features[key] ? 'bg-positive/5 border border-positive/20' : 'bg-card border border-border'}`}>
            {tool.features[key]
              ? <span class="text-positive text-lg">&#10003;</span>
              : <span class="text-muted/40 text-lg">&#10007;</span>
            }
            <span class={tool.features[key] ? 'text-text' : 'text-muted'}>{getFeatureLabel(key)}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- Pros & Cons -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-text mb-4">Pros & Cons</h2>
      <ProsCons pros={tool.pros} cons={tool.cons} />
    </section>

    <!-- Rating Breakdown -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-text mb-4">Rating Breakdown</h2>
      <div class="bg-card border border-border rounded-xl p-6">
        <div class="flex items-center gap-4 mb-6">
          <div class="text-5xl font-bold text-text">{tool.rating.toFixed(1)}</div>
          <div>
            <RatingStars rating={tool.rating} size="lg" showValue={false} />
            <p class="text-sm text-muted mt-1">Overall Rating</p>
          </div>
        </div>
        <div class="space-y-3">
          {Object.entries(tool.rating_breakdown).map(([key, value]) => (
            <div class="flex items-center gap-3">
              <span class="w-32 text-sm text-muted capitalize">{key.replace(/_/g, ' ')}</span>
              <div class="flex-1 h-2 bg-bg rounded-full overflow-hidden">
                <div class="h-full bg-featured rounded-full" style={`width: ${(value as number) * 20}%`}></div>
              </div>
              <span class="w-8 text-sm text-text text-right">{(value as number).toFixed(1)}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Key Takeaways & TL;DR -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-text mb-4">Key Takeaways</h2>
      <div class="bg-card border border-border rounded-xl p-6">
        <ul class="space-y-2">
          {tool.pros.map(pro => (
            <li class="flex items-start gap-2 text-sm text-muted">
              <span class="text-positive mt-0.5 shrink-0">&#10003;</span> {pro}
            </li>
          ))}
          <li class="flex items-start gap-2 text-sm text-muted">
            <span class="text-featured mt-0.5 shrink-0">&#9733;</span> Rated {tool.rating.toFixed(1)}/5 — best for {tool.best_for.join(', ')}
          </li>
          <li class="flex items-start gap-2 text-sm text-muted">
            <span class="text-featured mt-0.5 shrink-0">&#36;</span> {tool.pricing.starting_price === 0 ? 'Free tier available' : `Starts at $${tool.pricing.starting_price}/month`}{tool.pricing.has_free_tier && tool.pricing.starting_price > 0 ? ' (free tier also available)' : ''}
          </li>
        </ul>
      </div>
      <div class="mt-4 bg-card/50 border border-border rounded-xl p-5">
        <h3 class="text-sm font-semibold text-text mb-2">TL;DR</h3>
        <p class="text-sm text-muted leading-relaxed">
          {tool.name} is a {category?.name?.toLowerCase() || tool.category.replace(/-/g, ' ')} tool rated {tool.rating.toFixed(1)}/5, best suited for {tool.best_for.join(' and ')}. {tool.pricing.starting_price === 0 ? `It offers a free plan${tool.pricing.tiers.length > 1 ? `, with paid plans starting at $${tool.pricing.tiers.find(t => t.price_monthly > 0)?.price_monthly || 'N/A'}/month` : ''}.` : `Plans start at $${tool.pricing.starting_price}/month.`} {tool.pros[0]} and {tool.pros.length > 1 ? tool.pros[1].toLowerCase() : 'it performs well for its target audience'}.
        </p>
      </div>
    </section>

    <!-- Guides & Tutorials -->
    {toolGuides.length > 0 && (
      <section class="mb-10">
        <h2 class="text-2xl font-bold text-text mb-4">{tool.name} Guides</h2>
        <div class="grid sm:grid-cols-2 gap-3">
          {toolGuides.map(g => (
            <a href={`/blog/${g.slug}/`} class="group flex items-start gap-4 p-4 bg-card border border-border rounded-xl hover:border-primary/50 transition-colors">
              <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center shrink-0 group-hover:bg-primary/20 transition-colors">
                <span class="text-primary text-lg">&#128214;</span>
              </div>
              <div class="flex-1 min-w-0">
                <span class="text-text font-medium text-sm block truncate">{g.title}</span>
                <span class="text-muted text-xs block mt-1">{g.read_time_minutes} min read</span>
              </div>
              <span class="text-primary text-sm shrink-0 mt-1">&rarr;</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Compare This Tool -->
    {toolComparisons.length > 0 && (
      <section class="mb-10">
        <h2 class="text-2xl font-bold text-text mb-4">Compare {tool.name}</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
          {toolComparisons.map(c => {
            const otherSlug = c.tool_a === tool.slug ? c.tool_b : c.tool_a;
            const otherTool = getToolBySlug(otherSlug);
            return otherTool && (
              <a href={`/compare/${c.slug}/`} class="flex items-center gap-3 p-4 bg-card border border-border rounded-xl hover:border-primary/50 transition-colors">
                <span class="text-text font-medium text-sm">{tool.name} vs {otherTool.name}</span>
                <span class="ml-auto text-primary text-sm">&rarr;</span>
              </a>
            );
          })}
        </div>
        <a href={`/alternatives/${tool.slug}/`} class="inline-flex items-center mt-4 text-sm text-primary hover:text-primary-hover transition-colors">
          View all {tool.name} alternatives &rarr;
        </a>
      </section>
    )}

    <!-- Featured In -->
    {toolListicles.length > 0 && (
      <section class="mb-10">
        <h2 class="text-2xl font-bold text-text mb-4">{tool.name} Rankings</h2>
        <div class="space-y-2">
          {toolListicles.map(l => (
            <a href={`/best/${l.slug}/`} class="flex items-center gap-3 p-4 bg-card border border-border rounded-xl hover:border-primary/50 transition-colors">
              <span class="text-featured text-lg">&#9733;</span>
              <span class="text-text text-sm font-medium">{l.title}</span>
              <span class="ml-auto text-primary text-sm">&rarr;</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Similar Tools -->
    {similarTools.length > 0 && (
      <section class="mb-10">
        <h2 class="text-2xl font-bold text-text mb-4">Similar Tools</h2>
        <div class="grid md:grid-cols-3 gap-4">
          {similarTools.map(t => (
            <ToolCard
              name={t.name}
              slug={t.slug}
              category={t.category}
              description_short={t.description_short}
              rating={t.rating}
              pricing={t.pricing}
              markets={t.markets}
              best_for={t.best_for}
            />
          ))}
        </div>
      </section>
    )}

    <!-- Affiliate Banner -->
    {tool.affiliate_banner && tool.affiliate_url && (
      <div class="mb-6 flex justify-center">
        <a href={tool.affiliate_url} target="_blank" rel="nofollow sponsored" class="inline-block rounded-xl overflow-hidden hover:opacity-90 transition-opacity">
          <img
            src={tool.affiliate_banner.src}
            alt={tool.affiliate_banner.alt}
            width={tool.affiliate_banner.width}
            height={tool.affiliate_banner.height}
            loading="lazy"
            class="max-w-full h-auto"
          />
        </a>
      </div>
    )}

    <!-- Affiliate Disclosure -->
    <div class="bg-card/50 border border-border rounded-xl p-4 text-xs text-muted">
      <strong class="text-text">Affiliate Disclosure:</strong> Some links on this page may be affiliate links. If you sign up through our links, we may earn a commission at no extra cost to you. This helps us keep TradingToolsHub free and our reviews independent.
    </div>
  </div>
</BaseLayout>
