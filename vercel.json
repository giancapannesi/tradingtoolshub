{
  "redirects": [
    { "source": "/review/my-forex-funds/", "destination": "/prop-firms/", "statusCode": 301 },
    { "source": "/review/my-forex-funds", "destination": "/prop-firms/", "statusCode": 301 },
    { "source": "/review/surge-trader/", "destination": "/prop-firms/", "statusCode": 301 },
    { "source": "/review/surge-trader", "destination": "/prop-firms/", "statusCode": 301 },
    { "source": "/review/true-forex-funds/", "destination": "/prop-firms/", "statusCode": 301 },
    { "source": "/review/true-forex-funds", "destination": "/prop-firms/", "statusCode": 301 }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/review/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, s-maxage=604800" }
      ]
    },
    {
      "source": "/compare/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, s-maxage=604800" }
      ]
    },
    {
      "source": "/best/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, s-maxage=604800" }
      ]
    },
    {
      "source": "/alternatives/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, s-maxage=604800" }
      ]
    }
  ]
}
